{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "photoURL": { "type": "string", "format": "uri" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt"]
    },
    "Course": {
      "title": "Course",
      "description": "Represents an e-learning course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["Animation", "Video Production", "Authoring Tools", "Audio Production"] },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "thumbnail": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "title", "category", "teacherId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles." },
    "/courses/{courseId}": { "schema": "Course", "description": "Course information." }
  }
}
